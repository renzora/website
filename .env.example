# Database
DATABASE_URL=postgres://renzora:renzora@localhost:5432/renzora
POSTGRES_USER=renzora
POSTGRES_PASSWORD=renzora
POSTGRES_DB=renzora

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string

# Server
HOST=0.0.0.0
PORT=3000
RUST_LOG=info
SITE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://renzora.com

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=/uploads

# S3 Storage (DigitalOcean Spaces)
S3_ACCESS_KEY=DO00...
S3_SECRET_KEY=...
S3_ENDPOINT=https://sfo3.digitaloceanspaces.com
S3_BUCKET=renzora-assets
S3_PUBLIC_URL=https://renzora-assets.sfo3.cdn.digitaloceanspaces.com

# Stripe (optional — credits system won't work without these)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Discord OAuth2 (optional — Discord account linking)
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
